# Hermes Agent 环境变量示例
# 复制此文件到 ~/.hermes/.env 并填写需要的值
# 格式: KEY=VALUE（密码类变量建议加引号）

# ═══════════════════════════════════════════════════════════════
# Provider API Keys（必须配置至少一个）
# ═══════════════════════════════════════════════════════════════

# ── Nous Portal（推荐，免费层 + Premium）──
# 注册: https://nousportal.com/
NOUS_API_KEY=
NOUS_BASE_URL=

# ── OpenRouter（多模型路由）──
# 获取: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Anthropic Claude（直连）──
# 获取: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── OpenAI GPT（直连）──
# 获取: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── Google Gemini（直连）──
# 获取: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
GEMINI_API_KEY=

# ── DeepSeek（中国）──
# 获取: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# ── Z.AI / GLM（中国）──
# 获取: https://z.ai/
GLM_API_KEY=

# ── Kimi / Moonshot（中国）──
# 获取: https://platform.moonshot.cn/
KIMI_API_KEY=

# ── Alibaba DashScope / Qwen（中国）──
# 获取: https://modelstudio.console.alibabacloud.com/
DASHSCOPE_API_KEY=

# ── Hugging Face Inference Providers ──
# 获取: https://huggingface.co/settings/tokens
HF_TOKEN=

# ═══════════════════════════════════════════════════════════════
# Tool API Keys（可选，增强功能）
# ═══════════════════════════════════════════════════════════════

# ── Web Search / Extract ──
# Exa: https://exa.ai/
EXA_API_KEY=
# Parallel: https://parallel.ai/
PARALLEL_API_KEY=
# Firecrawl: https://firecrawl.dev/
FIRECRAWL_API_KEY=
# Tavily: https://app.tavily.com/
TAVILY_API_KEY=

# ── Browser Automation ──
# Browserbase: https://browserbase.com/
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# Browser Use: https://browser-use.com/
BROWSER_USE_API_KEY=
# Camofox（本地反检测浏览器）
CAMOFOX_URL=

# ── Image Generation ──
# FAL: https://fal.ai/
FAL_KEY=

# ── Voice / TTS ──
# OpenAI Whisper + TTS: https://platform.openai.com/api-keys
VOICE_TOOLS_OPENAI_KEY=
# ElevenLabs: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ── Memory ──
# Honcho: https://app.honcho.dev
HONCHO_API_KEY=
HONCHO_BASE_URL=

# ── RL Training ──
# Tinker: https://tinker-console.thinkingmachines.ai/keys
TINKER_API_KEY=
# WandB: https://wandb.ai/authorize
WANDB_API_KEY=

# ── GitHub（Skills Hub 发布）──
# 获取: https://github.com/settings/tokens
GITHUB_TOKEN=

# ═══════════════════════════════════════════════════════════════
# Messaging Platforms（Gateway 模式）
# ═══════════════════════════════════════════════════════════════

# ── Telegram ──
# Bot Token: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=
# Allowed Users: https://t.me/userinfobot 获取你的 ID
TELEGRAM_ALLOWED_USERS=

# ── Discord ──
# Bot Token: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USERS=

# ── Slack ──
# Bot Token (xoxb-): https://api.slack.com/apps
SLACK_BOT_TOKEN=
# App Token (xapp-): Socket Mode
SLACK_APP_TOKEN=

# ── Mattermost ──
MATTERMOST_URL=
MATTERMOST_TOKEN=
MATTERMOST_ALLOWED_USERS=

# ── Matrix ──
MATRIX_HOMESERVER=
MATRIX_ACCESS_TOKEN=
MATRIX_USER_ID=

# ── WhatsApp ──
WHATSAPP_MODE=
WHATSAPP_ENABLED=

# ── Signal ──
SIGNAL_ACCOUNT=
SIGNAL_HTTP_URL=
SIGNAL_ALLOWED_USERS=

# ═══════════════════════════════════════════════════════════════
# Advanced Settings
# ═══════════════════════════════════════════════════════════════

# Terminal Backend Override
TERMINAL_ENV=          # docker | ssh | modal | daytona
TERMINAL_SSH_KEY=
TERMINAL_SSH_PORT=

# Modal Sandbox Mode
TERMINAL_MODAL_MODE=   # auto | always | never

# Tool Gateway（Nous Subscribers）
TOOL_GATEWAY_DOMAIN=
TOOL_GATEWAY_USER_TOKEN=